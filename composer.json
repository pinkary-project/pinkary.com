{
    "name": "pinkary-project/pinkary.com",
    "type": "project",
    "require": {
        "php": "^8.4",
        "ext-imagick": "^3.7.0",
        "bacon/bacon-qr-code": "^3.1.1",
        "filament/filament": "^5.7.1",
        "intervention/image": "^3.11.8",
        "laravel/fortify": "^1.37.2",
        "laravel/framework": "^13.20",
        "laravel/nightwatch": "^1.28.4",
        "laravel/pennant": "^1.24.0",
        "laravel/socialite": "^5.28.0",
        "laravel/tinker": "^3.0.2",
        "league/flysystem-aws-s3-v3": "^3.35.2",
        "livewire/livewire": "^4.3.3",
        "matomo/device-detector": "^6.5.1",
        "nunomaduro/laravel-optimize-database": "^1.0.5",
        "panphp/pan": "^0.1.10",
        "ryangjchandler/laravel-cloudflare-turnstile": "^3.0.3",
        "scrivo/highlight.php": "^9.18.1.10",
        "spatie/laravel-mailcoach-mailer": "^1.6.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^4.4",
        "fakerphp/faker": "^1.24.1",
        "larastan/larastan": "^3.10.0",
        "laravel/boost": "^2.4.13",
        "laravel/pao": "^1.1.2",
        "laravel/pint": "dev-feat/blade-support",
        "laravel/sail": "^1.63.0",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.9.5",
        "pestphp/pest": "^5.0.0",
        "pestphp/pest-plugin-laravel": "^5.0.0",
        "pestphp/pest-plugin-type-coverage": "^5.0.0",
        "rector/rector": "^2.5.7"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --ansi"
        ],
        "bump:minor": [
            "composer update && composer bump",
            "npx npm-check-updates -u -t minor && npm install"
        ],
        "lint": "pint --parallel",
        "refactor": "rector",
        "test:lint": "pint --test --parallel",
        "test:refactor": "rector --dry-run",
        "test:types": "phpstan analyse",
        "test:arch": "pest --filter=arch",
        "test:type-coverage": "pest --type-coverage --min=100",
        "test:unit": "pest --parallel --coverage --exactly=98.9",
        "test": [
            "@test:lint",
            "@test:refactor",
            "@test:types",
            "@test:type-coverage",
            "@test:unit"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
